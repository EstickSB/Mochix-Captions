---
import '../styles/global.css';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>MochixSub — Subtítulos por IA en Segundos</title>
		<!-- Google Fonts for premium typography -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
		<style>
			:root {
				--font-heading: 'Outfit', sans-serif;
				--font-mono: 'JetBrains Mono', monospace;
			}
			body {
				font-family: var(--font-heading);
			}
			.glass {
				background: rgba(255, 255, 255, 0.7);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border: 1px solid rgba(255, 255, 255, 0.3);
			}
			.gradient-bg {
				background: radial-gradient(circle at top left, #f3f4f6 0%, #ffffff 50%, #f9fafb 100%);
				position: relative;
				overflow: hidden;
			}
			.gradient-bg::after {
				content: '';
				position: absolute;
				top: -10%;
				right: -10%;
				width: 50%;
				height: 50%;
				background: radial-gradient(circle, rgba(0, 0, 0, 0.03) 0%, transparent 70%);
				pointer-events: none;
			}
			.dropzone-active {
				border-color: #000 !important;
				background-color: rgba(0, 0, 0, 0.03) !important;
				transform: scale(1.01);
			}
			.loading-shimmer {
				background: linear-gradient(90deg, #f3f4f6 25%, #e5e7eb 50%, #f3f4f6 75%);
				background-size: 200% 100%;
				animation: shimmer 2s infinite;
			}
			@keyframes shimmer {
				0% { background-position: 200% 0; }
				100% { background-position: -200% 0; }
			}
		</style>
	</head>
	<body class="gradient-bg text-gray-900 font-sans antialiased selection:bg-black selection:text-white min-h-screen">
		<main class="min-h-screen flex items-center justify-center p-4 sm:p-8">
			<div class="w-full max-w-2xl glass rounded-[2.5rem] shadow-2xl p-8 sm:p-14 space-y-12 transition-all duration-500 hover:shadow-black/[0.05]">
				
				<!-- Titulo y Subtitulo Premium -->
				<header class="text-center space-y-4">
					<div class="inline-flex items-center justify-center p-4 bg-black text-white rounded-3xl mb-4 shadow-xl shadow-black/20 transform -rotate-3 hover:rotate-0 transition-transform duration-300">
						<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"></path>
						</svg>
					</div>
					<h1 class="text-5xl font-bold tracking-tight text-gray-950">MochixSub</h1>
					<p class="text-lg text-gray-500 font-normal max-w-md mx-auto">Tus videos con subtítulos profesionales generados en segundos por inteligencia artificial.</p>
				</header>

				<!-- Area de Subida -->
				<section class="space-y-6">
					<div id="drop-area" class="relative">
						<label for="dropzone-file" class="flex flex-col items-center justify-center w-full h-52 border-[3px] border-dashed border-gray-200 rounded-[2rem] cursor-pointer bg-white/50 hover:bg-white hover:border-black/20 transition-all duration-300 group overflow-hidden shadow-sm">
							<div class="flex flex-col items-center justify-center pt-5 pb-6 px-10 text-center relative z-10">
								<div id="icon-container" class="p-4 bg-gray-50 rounded-2xl mb-5 group-hover:bg-black group-hover:text-white transition-all duration-500 rotate-0 group-hover:rotate-12">
									<svg class="w-8 h-8" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 16">
										<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 13h3a3 3 0 0 0 0-6h-.025A5.56 5.56 0 0 0 16 6.5 5.5 5.5 0 0 0 5.207 5.021C5.137 5.017 5.071 5 5 5a4 4 0 0 0 0 8h2.167M10 15V6m0 0L8 8m2-2 2 2"/>
									</svg>
								</div>
								<p id="file-label-text" class="mb-2 text-base text-gray-500 font-medium">
									<span class="font-bold text-gray-900">Haz clic</span> o arrastra un archivo
								</p>
								<p class="text-sm text-gray-400">MP3, MP4, WAV o M4A • Máx. 100MB</p>
							</div>
							<input id="dropzone-file" type="file" class="hidden" accept="audio/*,video/*" />
							<!-- Shimmer effect for processing state -->
							<div id="loading-overlay" class="absolute inset-0 hidden loading-shimmer opacity-30 z-0"></div>
						</label>
					</div>

					<button id="btn-generate" disabled class="group relative w-full overflow-hidden py-4 px-6 text-base font-semibold text-white bg-black rounded-2xl transition-all duration-300 transform active:scale-[0.98] disabled:opacity-30 disabled:cursor-not-allowed hover:shadow-xl hover:shadow-black/10 flex items-center justify-center gap-3">
						<span id="btn-text">Generar Subtítulos</span>
						<svg id="btn-icon" class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path>
						</svg>
						<div id="spinner" class="hidden animate-spin rounded-full h-5 w-5 border-b-2 border-white"></div>
					</button>
				</section>

				<!-- Area de Resultados -->
				<section id="results-section" class="space-y-6 opacity-40 grayscale pointer-events-none transition-all duration-700">
					<div class="flex items-center justify-between mb-2 px-2">
						<h3 class="text-sm font-bold uppercase tracking-widest text-gray-400">Resultado SRT</h3>
						<div class="flex items-center gap-3 text-sm font-semibold text-gray-500">
							<div id="status-dot" class="w-2.5 h-2.5 bg-gray-300 rounded-full"></div>
							<span id="status-text">Pendiente</span>
						</div>
					</div>

					<div class="relative group">
						<textarea 
							id="result" 
							rows="8" 
							class="block p-5 w-full text-sm text-gray-700 bg-white/50 rounded-3xl border border-gray-200 focus:ring-2 focus:ring-black focus:border-transparent font-mono resize-none transition-all duration-300 shadow-sm" 
							placeholder="Tu archivo .srt aparecerá aquí..."
							readonly
						></textarea>
						
						<button id="btn-copy" class="absolute top-4 right-4 p-2.5 bg-white border border-gray-100 rounded-xl text-gray-400 hover:text-black hover:shadow-md transition-all active:scale-95 group" title="Copiar al portapapeles">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
							</svg>
						</button>
					</div>

					<button id="btn-download" disabled class="w-full py-4 px-6 text-base font-semibold text-gray-800 bg-white border-2 border-gray-100 rounded-2xl hover:bg-gray-50 hover:border-gray-200 transition-all duration-300 focus:ring-4 focus:ring-gray-100 disabled:opacity-30 flex items-center justify-center gap-3">
						<svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
						</svg>
						Descargar paquete .srt
					</button>
				</section>

				<footer class="text-center">
					<p class="text-xs text-gray-400 font-medium tracking-tight">Potenciado por Whisper AI • Procesado 100% en cliente</p>
				</footer>

			</div>
		</main>

		<!-- Tooltip minimalista para feedback de copia -->
		<div id="copy-toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-black text-white px-6 py-3 rounded-full text-sm font-bold shadow-2xl transition-all duration-500 opacity-0 translate-y-10 pointer-events-none z-50">
			¡Copiado al portapapeles! 🚀
		</div>

		<script>
			const fileInput = document.getElementById('dropzone-file');
			const fileLabelText = document.getElementById('file-label-text');
			const dropArea = document.getElementById('drop-area');
			const btnGenerate = document.getElementById('btn-generate');
			const btnText = document.getElementById('btn-text');
			const btnIcon = document.getElementById('btn-icon');
			const spinner = document.getElementById('spinner');
			const loadingOverlay = document.getElementById('loading-overlay');
			
			const resultsSection = document.getElementById('results-section');
			const statusDot = document.getElementById('status-dot');
			const statusText = document.getElementById('status-text');
			const resultArea = document.getElementById('result');
			const btnDownload = document.getElementById('btn-download');
			const btnCopy = document.getElementById('btn-copy');
			const copyToast = document.getElementById('copy-toast');

			let currentState = 'idle';
			let selectedFile = null;
			let generatedSrtText = '';

			function setState(state) {
				currentState = state;
				statusDot.className = 'w-2.5 h-2.5 rounded-full';

				switch(state) {
					case 'idle':
						spinner.classList.add('hidden');
						btnIcon.classList.remove('hidden');
						loadingOverlay.classList.add('hidden');
						btnText.textContent = 'Generar Subtítulos';
						
						if (!selectedFile) {
							statusDot.classList.add('bg-gray-300');
							statusText.textContent = 'Pendiente';
							btnGenerate.disabled = true;
							resultsSection.classList.add('opacity-40', 'grayscale', 'pointer-events-none');
						} else {
							statusDot.classList.add('bg-amber-400', 'animate-pulse');
							statusText.textContent = 'Listo para procesar';
							btnGenerate.disabled = false;
							resultsSection.classList.add('opacity-40', 'grayscale', 'pointer-events-none');
						}
						break;

					case 'processing':
						spinner.classList.remove('hidden');
						btnIcon.classList.add('hidden');
						loadingOverlay.classList.remove('hidden');
						btnText.textContent = 'Escuchando audio...';
						btnGenerate.disabled = true;
						
						statusDot.classList.add('bg-blue-500', 'animate-pulse');
						statusText.textContent = 'Analizando voz...';
						break;

					case 'done':
						spinner.classList.add('hidden');
						btnIcon.classList.remove('hidden');
						loadingOverlay.classList.add('hidden');
						btnText.textContent = '¡Proceso Completo!';
						btnGenerate.disabled = true;
						
						statusDot.classList.add('bg-green-500');
						statusDot.classList.remove('animate-pulse');
						statusText.textContent = 'Generado';
						
						resultsSection.classList.remove('opacity-40', 'grayscale', 'pointer-events-none');
						btnDownload.disabled = false;
						break;
				}
			}

			// Drag and Drop Effects
			['dragenter', 'dragover'].forEach(eventName => {
				dropArea.addEventListener(eventName, (e) => {
					e.preventDefault();
					dropArea.querySelector('label').classList.add('dropzone-active');
				}, false);
			});

			['dragleave', 'drop'].forEach(eventName => {
				dropArea.addEventListener(eventName, (e) => {
					e.preventDefault();
					dropArea.querySelector('label').classList.remove('dropzone-active');
				}, false);
			});

			dropArea.addEventListener('drop', (e) => {
				const dt = e.dataTransfer;
				const files = dt.files;
				if (files.length > 0) {
					fileInput.files = files;
					selectedFile = files[0];
					handleFileChange();
				}
			});

			fileInput.addEventListener('change', (e) => {
				if (e.target.files && e.target.files.length > 0) {
					selectedFile = e.target.files[0];
					handleFileChange();
				}
			});

			function handleFileChange() {
				fileLabelText.innerHTML = `<span class="text-black font-bold truncate max-w-[250px] inline-block">${selectedFile.name}</span>`;
				resultArea.value = '';
				setState('idle');
			}

			btnGenerate.addEventListener('click', () => {
				if (!selectedFile || currentState === 'processing') return;

				setState('processing');
				resultArea.value = '';

				setTimeout(() => {
					generatedSrtText = `1
00:00:00,450 --> 00:00:03,120
Hola, bienvenido al procesamiento de MochixSub.

2
00:00:03,120 --> 00:00:06,450
Estamos analizando el archivo: ${selectedFile.name}

3
00:00:06,450 --> 00:00:09,890
Tus subtítulos están listos para ser utilizados.`;

					resultArea.value = generatedSrtText;
					setState('done');
				}, 3000);
			});

			btnDownload.addEventListener('click', () => {
				if (currentState !== 'done' || !generatedSrtText) return;
				const blob = new Blob([generatedSrtText], { type: 'text/plain' });
				const url = URL.createObjectURL(blob);
				const link = document.createElement('a');
				link.href = url;
				let name = selectedFile.name.split('.')[0];
				link.download = `${name}_subtitles.srt`;
				document.body.appendChild(link);
				link.click();
				document.body.removeChild(link);
				URL.revokeObjectURL(url);
			});

			btnCopy.addEventListener('click', () => {
				if (!generatedSrtText) return;
				navigator.clipboard.writeText(generatedSrtText).then(() => {
					copyToast.classList.remove('opacity-0', 'translate-y-10');
					copyToast.classList.add('opacity-100', 'translate-y-0');
					setTimeout(() => {
						copyToast.classList.add('opacity-0', 'translate-y-10');
						copyToast.classList.remove('opacity-100', 'translate-y-0');
					}, 2000);
				});
			});

			setState('idle');
		</script>
	</body>
</html>
